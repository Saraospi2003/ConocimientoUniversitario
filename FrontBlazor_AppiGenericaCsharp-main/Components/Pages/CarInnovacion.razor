@page "/carinnovacion"
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<div class="crud-header">
    <div>
        <span>Módulo de innovación</span>
        <h2>Gestión de Características de Innovación</h2>
        <p>Administra las características, tipos y descripciones relacionadas con la innovación universitaria.</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(rol))
    {
        <strong class="role-pill">@rol</strong>
    }
</div>

<div class="mb-3">
    <label>ID</label>
    <input class="form-control" @bind="id" />
</div>

<div class="mb-3">
    <label>Nombre</label>
    <input class="form-control" @bind="nombre" />
</div>

<div class="mb-3">
    <label>Descripción</label>
    <input class="form-control" @bind="descripcion" />
</div>

<div class="mb-3">
    <label>Tipo</label>
    <input class="form-control" @bind="tipo" />
</div>

<div class="mb-3">
    @if (rol == "Administrador" || rol == "Docente")
    {
        <button class="btn btn-primary me-2" @onclick="Guardar">Guardar</button>
        <button class="btn btn-warning me-2" @onclick="Actualizar">Actualizar</button>
        <button class="btn btn-secondary" @onclick="Limpiar">Limpiar</button>
    }
    else if (rol == "Consultor")
    {
        <div class="alert alert-warning">
            Estás ingresando como Consultor. Solo puedes visualizar la información.
        </div>
    }
</div>

@if (!string.IsNullOrWhiteSpace(mensaje))
{
    <div class="alert alert-info">@mensaje</div>
}

<h4>Listado de características de innovación</h4>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>ID</th>
            <th>Nombre</th>
            <th>Descripción</th>
            <th>Tipo</th>
            <th>Acciones</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in carInnovaciones)
        {
            var idEliminar = item["id"]?.ToString() ?? "";

            <tr>
                <td>@item["id"]</td>
                <td>@item["nombre"]</td>
                <td>@item["descripcion"]</td>
                <td>@item["tipo"]</td>
                <td>
                    @if (rol == "Administrador" || rol == "Docente")
                    {
                        <button class="btn btn-sm btn-info me-1" @onclick="() => Seleccionar(item)">
                            Editar
                        </button>
                    }

                    @if (rol == "Administrador")
                    {
                        <button class="btn btn-sm btn-danger" @onclick="() => Eliminar(idEliminar)">
                            Eliminar
                        </button>
                    }

                    @if (rol == "Consultor")
                    {
                        <span class="text-muted">Solo lectura</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private string rol = "";
    private List<Dictionary<string, object?>> carInnovaciones = new();

    private string id = "";
    private string nombre = "";
    private string descripcion = "";
    private string tipo = "";
    private string mensaje = "";

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            rol = await JS.InvokeAsync<string>("localStorage.getItem", "rol") ?? "";
            StateHasChanged();
        }
    }

    private async Task CargarDatos()
    {
        carInnovaciones = await Api.ListarAsync("CarInnovacion");
    }

    private async Task Guardar()
    {
        if (rol == "Consultor")
        {
            mensaje = "No tienes permiso para guardar información. Tu rol es Consultor.";
            return;
        }

        if (string.IsNullOrWhiteSpace(id) ||
            string.IsNullOrWhiteSpace(nombre) ||
            string.IsNullOrWhiteSpace(descripcion) ||
            string.IsNullOrWhiteSpace(tipo))
        {
            mensaje = "Completa todos los campos.";
            StateHasChanged();
            return;
        }

        var datos = new Dictionary<string, object?>
        {
            { "id", id },
            { "nombre", nombre },
            { "descripcion", descripcion },
            { "tipo", tipo }
        };

        var resultado = await Api.CrearAsync("CarInnovacion", datos);
        mensaje = resultado.mensaje;

        if (resultado.exito)
        {
            Limpiar();
            await CargarDatos();
        }
    }

    private async Task Actualizar()
    {
        if (rol == "Consultor")
        {
            mensaje = "No tienes permiso para actualizar información. Tu rol es Consultor.";
            return;
        }

        if (string.IsNullOrWhiteSpace(id) ||
            string.IsNullOrWhiteSpace(nombre) ||
            string.IsNullOrWhiteSpace(descripcion) ||
            string.IsNullOrWhiteSpace(tipo))
        {
            mensaje = "Completa todos los campos.";
            StateHasChanged();
            return;
        }

        var datos = new Dictionary<string, object?>
        {
            { "id", id },
            { "nombre", nombre },
            { "descripcion", descripcion },
            { "tipo", tipo }
        };

        var resultado = await Api.ActualizarAsync("CarInnovacion", "id", id, datos);
        mensaje = resultado.mensaje;

        if (resultado.exito)
        {
            Limpiar();
            await CargarDatos();
        }
    }

    private async Task Eliminar(string idEliminar)
    {
        if (rol != "Administrador")
        {
            mensaje = "Solo el Administrador puede eliminar registros.";
            return;
        }

        var resultado = await Api.EliminarAsync("CarInnovacion", "id", idEliminar);
        mensaje = resultado.mensaje;

        await CargarDatos();
    }

    private void Seleccionar(Dictionary<string, object?> item)
    {
        if (rol == "Consultor")
        {
            mensaje = "No tienes permiso para editar. Tu rol es Consultor.";
            return;
        }

        id = item["id"]?.ToString() ?? "";
        nombre = item["nombre"]?.ToString() ?? "";
        descripcion = item["descripcion"]?.ToString() ?? "";
        tipo = item["tipo"]?.ToString() ?? "";
        mensaje = "Registro cargado para edición.";
    }

    private void Limpiar()
    {
        id = "";
        nombre = "";
        descripcion = "";
        tipo = "";
        mensaje = "";
    }
}