@page "/docentedepartamento"
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<div class="crud-header">
    <div>
        <span>Módulo docente</span>
        <h2>Gestión de Docentes por Departamento</h2>
        <p>Administra la relación entre docentes, departamentos, dedicación, modalidad y fechas de vinculación.</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(rol))
    {
        <strong class="role-pill">@rol</strong>
    }
</div>

<div class="mb-3">
    <label>Docente</label>
    <input class="form-control" @bind="docente" />
</div>

<div class="mb-3">
    <label>Departamento</label>
    <select class="form-control" @bind="departamento">
        <option value="">Seleccione una facultad</option>
        @foreach (var fac in facultadesLista)
        {
            <option value="@fac["id"]">@fac["nombre"]</option>
        }
    </select>
</div>

<div class="mb-3">
    <label>Dedicación</label>
    <input class="form-control" @bind="dedicacion" />
</div>

<div class="mb-3">
    <label>Modalidad</label>
    <input class="form-control" @bind="modalidad" />
</div>

<div class="mb-3">
    <label>Fecha ingreso</label>
    <input type="date" class="form-control" @bind="fechaIngreso" />
</div>

<div class="mb-3">
    <label>Fecha salida</label>
    <input type="date" class="form-control" @bind="fechaSalida" />
</div>

<div class="mb-3">
    @if (rol == "Administrador" || rol == "Docente")
    {
        <button class="btn btn-primary me-2" @onclick="Guardar">Guardar</button>
        <button class="btn btn-secondary" @onclick="Limpiar">Limpiar</button>
    }
    else if (rol == "Consultor")
    {
        <div class="alert alert-warning">
            Estás ingresando como Consultor. Solo puedes visualizar la información.
        </div>
    }
</div>

@if (!string.IsNullOrWhiteSpace(mensaje))
{
    <div class="alert alert-info">@mensaje</div>
}

<h4>Listado Docente Departamento</h4>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Docente</th>
            <th>Departamento</th>
            <th>Dedicación</th>
            <th>Modalidad</th>
            <th>Fecha ingreso</th>
            <th>Fecha salida</th>
            <th>Acciones</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in registros)
        {
            var docenteEliminar = item["docente"]?.ToString() ?? "";
            var depEliminar = item["departamento"]?.ToString() ?? "";

            <tr>
                <td>@item["docente"]</td>
                <td>@item["departamento"]</td>
                <td>@item["dedicacion"]</td>
                <td>@item["modalidad"]</td>
                <td>@item["fechaIngreso"]</td>
                <td>@item["fechaSalida"]</td>
                <td>
                    @if (rol == "Administrador")
                    {
                        <button class="btn btn-sm btn-danger" @onclick="() => Eliminar(docenteEliminar, depEliminar)">
                            Eliminar
                        </button>
                    }
                    else
                    {
                        <span class="text-muted">Solo lectura</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private string rol = "";

    private List<Dictionary<string, object?>> registros = new();
    private List<Dictionary<string, object?>> facultadesLista = new();

    private string docente = "";
    private string departamento = "";
    private string dedicacion = "";
    private string modalidad = "";
    private string mensaje = "";

    private DateTime? fechaIngreso;
    private DateTime? fechaSalida;

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
        await CargarFacultades();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            rol = await JS.InvokeAsync<string>("localStorage.getItem", "rol") ?? "";
            StateHasChanged();
        }
    }

    private async Task CargarDatos()
    {
        registros = await Api.ListarAsync("DocenteDepartamento");
    }

    private async Task CargarFacultades()
    {
        facultadesLista = await Api.ListarAsync("Facultad");
    }

    private async Task Guardar()
    {
        if (rol == "Consultor")
        {
            mensaje = "No tienes permiso para guardar información. Tu rol es Consultor.";
            return;
        }

        if (string.IsNullOrWhiteSpace(docente) ||
            string.IsNullOrWhiteSpace(departamento) ||
            string.IsNullOrWhiteSpace(dedicacion) ||
            string.IsNullOrWhiteSpace(modalidad))
        {
            mensaje = "Completa los campos obligatorios.";
            return;
        }

        var datos = new Dictionary<string, object?>
        {
            { "docente", docente },
            { "departamento", departamento },
            { "dedicacion", dedicacion },
            { "modalidad", modalidad },
            { "fechaIngreso", fechaIngreso?.ToString("yyyy-MM-dd") },
            { "fechaSalida", fechaSalida?.ToString("yyyy-MM-dd") }
        };

        var resultado = await Api.CrearAsync("DocenteDepartamento", datos);
        mensaje = resultado.mensaje;

        if (resultado.exito)
        {
            Limpiar();
            await CargarDatos();
        }
    }

    private async Task Eliminar(string docenteEliminar, string depEliminar)
    {
        if (rol != "Administrador")
        {
            mensaje = "Solo el Administrador puede eliminar registros.";
            return;
        }

        var resultado = await Api.EliminarCompuestoAsync("DocenteDepartamento",
            new Dictionary<string, string>
            {
                { "docente", docenteEliminar },
                { "departamento", depEliminar }
            });

        mensaje = resultado.mensaje;
        await CargarDatos();
    }

    private void Limpiar()
    {
        docente = "";
        departamento = "";
        dedicacion = "";
        modalidad = "";
        fechaIngreso = null;
        fechaSalida = null;
        mensaje = "";
    }
}