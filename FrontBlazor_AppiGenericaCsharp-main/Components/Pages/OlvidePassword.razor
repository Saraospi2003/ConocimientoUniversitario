@page "/olvide-password"
@rendermode InteractiveServer
@inject HttpClient Http
@inject NavigationManager Nav

<h3>Recuperar contraseña</h3>

<div class="mb-3">
    <label>Correo registrado</label>
    <input class="form-control" @bind="correo" />
</div>

<button class="btn btn-primary" @onclick="EnviarCodigo">
    Enviar código
</button>

<hr />

<div class="mb-3">
    <label>Código recibido</label>
    <input class="form-control" @bind="datos.Codigo" />
</div>

<div class="mb-3">
    <label>Nueva contraseña</label>
    <input type="password" class="form-control" @bind="datos.NuevaPassword" />
</div>

<button class="btn btn-success" @onclick="RecuperarPassword">
    Cambiar contraseña
</button>

<p class="mt-3">@mensaje</p>

@code {
    string correo = "";
    string mensaje = "";

    RecuperarPasswordDto datos = new();

    async Task EnviarCodigo()
    {
        var respuesta = await Http.PostAsync(
            $"api/Auth/enviar-codigo?correo={correo}", null);

        if (respuesta.IsSuccessStatusCode)
        {
            mensaje = "Código enviado al correo";
            datos.Correo = correo;
        }
        else
        {
            mensaje = "No se pudo enviar el código. Verifica el correo.";
        }
    }

    async Task RecuperarPassword()
    {
        datos.Correo = correo;

        var respuesta = await Http.PutAsJsonAsync(
            "api/Auth/recuperar-password", datos);

        if (respuesta.IsSuccessStatusCode)
        {
            mensaje = "Contraseña cambiada correctamente";
            Nav.NavigateTo("/login");
        }
        else
        {
            mensaje = "Código incorrecto o expirado";
        }
    }

    public class RecuperarPasswordDto
    {
        public string Correo { get; set; } = "";
        public string Codigo { get; set; } = "";
        public string NuevaPassword { get; set; } = "";
    }
}