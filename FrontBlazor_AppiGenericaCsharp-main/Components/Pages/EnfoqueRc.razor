@page "/enfoque_rc"
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<div class="crud-header">
    <div>
        <span>Relación académica</span>
        <h2>Enfoques por Registro Calificado</h2>
        <p>Asocia los enfoques académicos con los registros calificados de los programas.</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(rol))
    {
        <strong class="role-pill">@rol</strong>
    }
</div>

<div class="mb-3">
    <label>Enfoque</label>
    <select class="form-control" @bind="enfoque">
        <option value="">Seleccione un enfoque</option>
        @foreach (var enf in enfoquesLista)
        {
            <option value="@enf["id"]">@enf["nombre"]</option>
        }
    </select>
</div>

<div class="mb-3">
    <label>Registro Calificado</label>
    <select class="form-control" @bind="registroCalificado">
        <option value="">Seleccione un registro</option>
        @foreach (var reg in registrosLista)
        {
            <option value="@reg["codigo"]">@reg["codigo"]</option>
        }
    </select>
</div>

<div class="mb-3">
    @if (rol == "Administrador" || rol == "Docente")
    {
        <button class="btn btn-primary me-2" @onclick="Guardar">Guardar</button>
        <button class="btn btn-secondary" @onclick="Limpiar">Limpiar</button>
    }
    else if (rol == "Consultor")
    {
        <div class="alert alert-warning">
            Estás ingresando como Consultor. Solo puedes visualizar la información.
        </div>
    }
</div>

@if (!string.IsNullOrWhiteSpace(mensaje))
{
    <div class="alert alert-info">@mensaje</div>
}

<h4>Listado de Enfoque_rc</h4>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Enfoque</th>
            <th>Registro Calificado</th>
            <th>Acciones</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in registros)
        {
            var enfoqueEliminar = item["enfoque"]?.ToString() ?? "";
            var registroEliminar = item["registroCalificado"]?.ToString() ?? "";

            <tr>
                <td>@item["enfoque"]</td>
                <td>@item["registroCalificado"]</td>
                <td>
                    @if (rol == "Administrador")
                    {
                        <button class="btn btn-sm btn-danger" @onclick="() => Eliminar(enfoqueEliminar, registroEliminar)">
                            Eliminar
                        </button>
                    }
                    else
                    {
                        <span class="text-muted">Solo lectura</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private string rol = "";

    private List<Dictionary<string, object?>> registros = new();
    private List<Dictionary<string, object?>> enfoquesLista = new();
    private List<Dictionary<string, object?>> registrosLista = new();

    private string enfoque = "";
    private string registroCalificado = "";
    private string mensaje = "";

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
        await CargarEnfoques();
        await CargarRegistros();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            rol = await JS.InvokeAsync<string>("localStorage.getItem", "rol") ?? "";
            StateHasChanged();
        }
    }

    private async Task CargarDatos()
    {
        registros = await Api.ListarAsync("EnfoqueRc");
    }

    private async Task CargarEnfoques()
    {
        enfoquesLista = await Api.ListarAsync("Enfoque");
    }

    private async Task CargarRegistros()
    {
        registrosLista = await Api.ListarAsync("RegistroCalificado");
    }

    private async Task Guardar()
    {
        if (rol == "Consultor")
        {
            mensaje = "No tienes permiso para guardar información. Tu rol es Consultor.";
            return;
        }

        if (string.IsNullOrWhiteSpace(enfoque) ||
            string.IsNullOrWhiteSpace(registroCalificado))
        {
            mensaje = "Completa todos los campos.";
            return;
        }

        var datos = new Dictionary<string, object?>
        {
            { "enfoque", enfoque },
            { "registroCalificado", registroCalificado }
        };

        var resultado = await Api.CrearAsync("EnfoqueRc", datos);
        mensaje = resultado.mensaje;

        if (resultado.exito)
        {
            Limpiar();
            await CargarDatos();
        }
    }

    private async Task Eliminar(string enfoqueEliminar, string registroEliminar)
    {
        if (rol != "Administrador")
        {
            mensaje = "Solo el Administrador puede eliminar registros.";
            return;
        }

        var resultado = await Api.EliminarCompuestoAsync("EnfoqueRc",
            new Dictionary<string, string>
            {
                { "enfoque", enfoqueEliminar },
                { "registroCalificado", registroEliminar }
            });

        mensaje = resultado.mensaje;
        await CargarDatos();
    }

    private void Limpiar()
    {
        enfoque = "";
        registroCalificado = "";
        mensaje = "";
    }
}