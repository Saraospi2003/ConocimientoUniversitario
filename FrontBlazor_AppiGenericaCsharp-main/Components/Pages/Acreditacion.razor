@page "/acreditacion"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<h3>CRUD Acreditación</h3>

<div class="mb-3">
    <label>Resolución</label>
    <input class="form-control" @bind="resolucion" />
</div>

<div class="mb-3">
    <label>Tipo</label>
    <input class="form-control" @bind="tipo" />
</div>

<div class="mb-3">
    <label>Calificación</label>
    <input class="form-control" @bind="calificacion" />
</div>

<div class="mb-3">
    <label>Fecha inicio</label>
    <input class="form-control" @bind="fechaInicio" />
</div>

<div class="mb-3">
    <label>Fecha fin</label>
    <input class="form-control" @bind="fechaFin" />
</div>

<select class="form-control" @bind="programa">
    <option value="">Seleccione un programa</option>
    @foreach (var pro in programasLista)
    {
        <option value="@pro["id"]">@pro["nombre"]</option>
    }
</select>

<div class="mb-3">
    <button class="btn btn-primary me-2" @onclick="Guardar">Guardar</button>
    <button class="btn btn-warning me-2" @onclick="Actualizar">Actualizar</button>
    <button class="btn btn-secondary" @onclick="Limpiar">Limpiar</button>
</div>

@if (!string.IsNullOrWhiteSpace(mensaje))
{
    <div class="alert alert-info">@mensaje</div>
}

<h4>Listado de acreditaciones</h4>
<table class="table table-bordered">
    <thead>
        <tr>
            <th>Resolución</th>
            <th>Tipo</th>
            <th>Calificación</th>
            <th>Programa</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in acreditaciones)
        {
            var idEliminar = item["resolucion"]?.ToString() ?? "";
            <tr>
                <td>@item["resolucion"]</td>
                <td>@item["tipo"]</td>
                <td>@item["calificacion"]</td>
                <td>@item["programa"]</td>
                <td>
                    <button class="btn btn-sm btn-info me-1" @onclick="() => Seleccionar(item)">Editar</button>
                    <button class="btn btn-sm btn-danger" @onclick="() => Eliminar(idEliminar)">Eliminar</button>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private List<Dictionary<string, object?>> acreditaciones = new();
    private string resolucion = "", tipo = "", calificacion = "", fechaInicio = "", fechaFin = "", programa = "", mensaje = "";

    private List<Dictionary<string, object?>> programasLista = new();

    private async Task CargarProgramas()
    => programasLista = await Api.ListarAsync("Programa");
    protected override async Task OnInitializedAsync()
{
    await CargarDatos();
    await CargarProgramas();
}

    private async Task CargarDatos()
        => acreditaciones = await Api.ListarAsync("Acreditacion");

    private async Task Guardar()
    {
        if (string.IsNullOrWhiteSpace(resolucion) || string.IsNullOrWhiteSpace(tipo) ||
            string.IsNullOrWhiteSpace(calificacion) || string.IsNullOrWhiteSpace(fechaInicio) ||
            string.IsNullOrWhiteSpace(fechaFin) || string.IsNullOrWhiteSpace(programa))
        {
            mensaje = "Completa todos los campos.";
            return;
        }

        var datos = new Dictionary<string, object?>
        {
            { "resolucion", resolucion },
            { "tipo", tipo },
            { "calificacion", calificacion },
            { "fechaInicio", fechaInicio },
            { "fechaFin", fechaFin },
            { "programa", programa }
        };

        var resultado = await Api.CrearAsync("Acreditacion", datos);
        mensaje = resultado.mensaje;
        if (resultado.exito) { Limpiar(); await CargarDatos(); }
    }

    private async Task Actualizar()
    {
        var datos = new Dictionary<string, object?>
        {
            { "resolucion", resolucion },
            { "tipo", tipo },
            { "calificacion", calificacion },
            { "fechaInicio", fechaInicio },
            { "fechaFin", fechaFin },
            { "programa", programa }
        };

        var resultado = await Api.ActualizarAsync("Acreditacion", "resolucion", resolucion, datos);
        mensaje = resultado.mensaje;
        if (resultado.exito) { Limpiar(); await CargarDatos(); }
    }

    private async Task Eliminar(string idEliminar)
    {
        var resultado = await Api.EliminarAsync("Acreditacion", "resolucion", idEliminar);
        mensaje = resultado.mensaje;
        await CargarDatos();
    }

    private void Seleccionar(Dictionary<string, object?> item)
    {
        resolucion = item["resolucion"]?.ToString() ?? "";
        tipo = item["tipo"]?.ToString() ?? "";
        calificacion = item["calificacion"]?.ToString() ?? "";
        fechaInicio = item["fechaInicio"]?.ToString() ?? "";
        fechaFin = item["fechaFin"]?.ToString() ?? "";
        programa = item["programa"]?.ToString() ?? "";
        mensaje = "Registro cargado para edición.";
    }

    private void Limpiar()
    {
        resolucion = "";
        tipo = "";
        calificacion = "";
        fechaInicio = "";
        fechaFin = "";
        programa = "";
        mensaje = "";
    }
}