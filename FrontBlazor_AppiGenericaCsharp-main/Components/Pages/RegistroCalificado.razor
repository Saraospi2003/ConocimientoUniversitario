@page "/registrocalificado"
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<div class="crud-header">
    <div>
        <span>Módulo de calidad académica</span>
        <h2>Gestión de Registros Calificados</h2>
        <p>Administra códigos, créditos, metodologías, fechas, duración, titulación y programas asociados.</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(rol))
    {
        <strong class="role-pill">@rol</strong>
    }
</div>

<div class="mb-3">
    <label>Código</label>
    <input class="form-control" @bind="codigo" />
</div>

<div class="mb-3">
    <label>Cantidad créditos</label>
    <input class="form-control" @bind="cantCred" />
</div>

<div class="mb-3">
    <label>Horas acompañamiento</label>
    <input class="form-control" @bind="horaAcom" />
</div>

<div class="mb-3">
    <label>Horas independientes</label>
    <input class="form-control" @bind="horaInd" />
</div>

<div class="mb-3">
    <label>Metodología</label>
    <input class="form-control" @bind="metodologia" />
</div>

<div class="mb-3">
    <label>Fecha inicio</label>
    <input type="date" class="form-control" @bind="fechaInicio" />
</div>

<div class="mb-3">
    <label>Fecha fin</label>
    <input type="date" class="form-control" @bind="fechaFin" />
</div>

<div class="mb-3">
    <label>Duración años</label>
    <input class="form-control" @bind="duracionAnios" />
</div>

<div class="mb-3">
    <label>Duración semestres</label>
    <input class="form-control" @bind="duracionSemes" />
</div>

<div class="mb-3">
    <label>Tipo titulación</label>
    <input class="form-control" @bind="tipoTitulacion" />
</div>

<div class="mb-3">
    <label>Programa</label>
    <select class="form-control" @bind="programa">
        <option value="">Seleccione un programa</option>

        @foreach (var pro in programasLista)
        {
            <option value="@pro["id"]">@pro["nombre"]</option>
        }
    </select>
</div>

<div class="mb-3">
    @if (rol == "Administrador" || rol == "Docente")
    {
        <button class="btn btn-primary me-2" @onclick="Guardar">
            Guardar
        </button>

        <button class="btn btn-warning me-2" @onclick="Actualizar">
            Actualizar
        </button>

        <button class="btn btn-secondary" @onclick="Limpiar">
            Limpiar
        </button>
    }
    else if (rol == "Consultor")
    {
        <div class="alert alert-warning">
            Estás ingresando como Consultor. Solo puedes visualizar la información.
        </div>
    }
</div>

@if (!string.IsNullOrWhiteSpace(mensaje))
{
    <div class="alert alert-info">@mensaje</div>
}

<h4>Listado de registros calificados</h4>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Código</th>
            <th>Metodología</th>
            <th>Fecha inicio</th>
            <th>Fecha fin</th>
            <th>Programa</th>
            <th>Acciones</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in registros)
        {
            var codigoEliminar = item["codigo"]?.ToString() ?? "";

            <tr>
                <td>@item["codigo"]</td>
                <td>@item["metodologia"]</td>
                <td>@item["fechaInicio"]</td>
                <td>@item["fechaFin"]</td>
                <td>@item["programa"]</td>
                <td>
                    @if (rol == "Administrador" || rol == "Docente")
                    {
                        <button class="btn btn-sm btn-info me-1" @onclick="() => Seleccionar(item)">
                            Editar
                        </button>
                    }

                    @if (rol == "Administrador")
                    {
                        <button class="btn btn-sm btn-danger" @onclick="() => Eliminar(codigoEliminar)">
                            Eliminar
                        </button>
                    }

                    @if (rol == "Consultor")
                    {
                        <span class="text-muted">Solo lectura</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private string rol = "";

    private List<Dictionary<string, object?>> registros = new();
    private List<Dictionary<string, object?>> programasLista = new();

    private string codigo = "";
    private string cantCred = "";
    private string horaAcom = "";
    private string horaInd = "";
    private string metodologia = "";
    private string duracionAnios = "";
    private string duracionSemes = "";
    private string tipoTitulacion = "";
    private string programa = "";
    private string mensaje = "";

    private DateTime? fechaInicio;
    private DateTime? fechaFin;

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
        await CargarProgramas();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            rol = await JS.InvokeAsync<string>("localStorage.getItem", "rol") ?? "";
            StateHasChanged();
        }
    }

    private async Task CargarDatos()
    {
        registros = await Api.ListarAsync("RegistroCalificado");
    }

    private async Task CargarProgramas()
    {
        programasLista = await Api.ListarAsync("Programa");
    }

    private async Task Guardar()
    {
        if (rol == "Consultor")
        {
            mensaje = "No tienes permiso para guardar información. Tu rol es Consultor.";
            return;
        }

        if (string.IsNullOrWhiteSpace(codigo) ||
            string.IsNullOrWhiteSpace(cantCred) ||
            string.IsNullOrWhiteSpace(horaAcom) ||
            string.IsNullOrWhiteSpace(horaInd) ||
            string.IsNullOrWhiteSpace(metodologia) ||
            fechaInicio == null ||
            fechaFin == null ||
            string.IsNullOrWhiteSpace(duracionAnios) ||
            string.IsNullOrWhiteSpace(duracionSemes) ||
            string.IsNullOrWhiteSpace(tipoTitulacion) ||
            string.IsNullOrWhiteSpace(programa))
        {
            mensaje = "Completa todos los campos.";
            return;
        }

        var datos = new Dictionary<string, object?>
        {
            { "codigo", codigo },
            { "cantCred", cantCred },
            { "horaAcom", horaAcom },
            { "horaInd", horaInd },
            { "metodologia", metodologia },
            { "fechaInicio", fechaInicio?.ToString("yyyy-MM-dd") },
            { "fechaFin", fechaFin?.ToString("yyyy-MM-dd") },
            { "duracionAnios", duracionAnios },
            { "duracionSemes", duracionSemes },
            { "tipoTitulacion", tipoTitulacion },
            { "programa", programa }
        };

        var resultado = await Api.CrearAsync("RegistroCalificado", datos);
        mensaje = resultado.mensaje;

        if (resultado.exito)
        {
            Limpiar();
            await CargarDatos();
        }
    }

    private async Task Actualizar()
    {
        if (rol == "Consultor")
        {
            mensaje = "No tienes permiso para actualizar información. Tu rol es Consultor.";
            return;
        }

        if (string.IsNullOrWhiteSpace(codigo))
        {
            mensaje = "Selecciona un registro para actualizar.";
            return;
        }

        var datos = new Dictionary<string, object?>
        {
            { "codigo", codigo },
            { "cantCred", cantCred },
            { "horaAcom", horaAcom },
            { "horaInd", horaInd },
            { "metodologia", metodologia },
            { "fechaInicio", fechaInicio?.ToString("yyyy-MM-dd") },
            { "fechaFin", fechaFin?.ToString("yyyy-MM-dd") },
            { "duracionAnios", duracionAnios },
            { "duracionSemes", duracionSemes },
            { "tipoTitulacion", tipoTitulacion },
            { "programa", programa }
        };

        var resultado = await Api.ActualizarAsync("RegistroCalificado", "codigo", codigo, datos);
        mensaje = resultado.mensaje;

        if (resultado.exito)
        {
            Limpiar();
            await CargarDatos();
        }
    }

    private async Task Eliminar(string codigoEliminar)
    {
        if (rol != "Administrador")
        {
            mensaje = "Solo el Administrador puede eliminar registros.";
            return;
        }

        var resultado = await Api.EliminarAsync("RegistroCalificado", "codigo", codigoEliminar);
        mensaje = resultado.mensaje;

        await CargarDatos();
    }

    private void Seleccionar(Dictionary<string, object?> item)
    {
        if (rol == "Consultor")
        {
            mensaje = "No tienes permiso para editar. Tu rol es Consultor.";
            return;
        }

        codigo = item["codigo"]?.ToString() ?? "";
        cantCred = item["cantCred"]?.ToString() ?? "";
        horaAcom = item["horaAcom"]?.ToString() ?? "";
        horaInd = item["horaInd"]?.ToString() ?? "";
        metodologia = item["metodologia"]?.ToString() ?? "";
        duracionAnios = item["duracionAnios"]?.ToString() ?? "";
        duracionSemes = item["duracionSemes"]?.ToString() ?? "";
        tipoTitulacion = item["tipoTitulacion"]?.ToString() ?? "";
        programa = item["programa"]?.ToString() ?? "";

        fechaInicio = DateTime.TryParse(item["fechaInicio"]?.ToString(), out var fi) ? fi : null;
        fechaFin = DateTime.TryParse(item["fechaFin"]?.ToString(), out var ff) ? ff : null;

        mensaje = "Registro cargado para edición.";
    }

    private void Limpiar()
    {
        codigo = "";
        cantCred = "";
        horaAcom = "";
        horaInd = "";
        metodologia = "";
        duracionAnios = "";
        duracionSemes = "";
        tipoTitulacion = "";
        programa = "";
        fechaInicio = null;
        fechaFin = null;
        mensaje = "";
    }
}