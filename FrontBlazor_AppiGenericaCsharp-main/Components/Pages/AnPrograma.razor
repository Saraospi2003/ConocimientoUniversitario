@page "/anprograma"
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<div class="crud-header">
    <div>
        <span>Relación normativa</span>
        <h2>Aspectos Normativos por Programa</h2>
        <p>Asocia los aspectos normativos con los programas académicos del sistema.</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(rol))
    {
        <strong class="role-pill">@rol</strong>
    }
</div>

<div class="mb-3">
    <label>Aspecto Normativo</label>
    <select class="form-control" @bind="aspectoNormativo">
        <option value="">Seleccione un aspecto normativo</option>
        @foreach (var asp in aspectosLista)
        {
            <option value="@asp["id"]">@asp["tipo"]</option>
        }
    </select>
</div>

<div class="mb-3">
    <label>Programa</label>
    <select class="form-control" @bind="programa">
        <option value="">Seleccione un programa</option>
        @foreach (var pro in programasLista)
        {
            <option value="@pro["id"]">@pro["nombre"]</option>
        }
    </select>
</div>

<div class="mb-3">
    @if (rol == "Administrador" || rol == "Docente")
    {
        <button class="btn btn-primary me-2" @onclick="Guardar">Guardar</button>
        <button class="btn btn-secondary" @onclick="Limpiar">Limpiar</button>
    }
    else if (rol == "Consultor")
    {
        <div class="alert alert-warning">
            Estás ingresando como Consultor. Solo puedes visualizar la información.
        </div>
    }
</div>

@if (!string.IsNullOrWhiteSpace(mensaje))
{
    <div class="alert alert-info">@mensaje</div>
}

<h4>Listado de An_programa</h4>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Aspecto Normativo</th>
            <th>Programa</th>
            <th>Acciones</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in registros)
        {
            var aspectoEliminar = item["aspectoNormativo"]?.ToString() ?? "";
            var programaEliminar = item["programa"]?.ToString() ?? "";

            <tr>
                <td>@item["aspectoNormativo"]</td>
                <td>@item["programa"]</td>
                <td>
                    @if (rol == "Administrador")
                    {
                        <button class="btn btn-sm btn-danger" @onclick="() => Eliminar(aspectoEliminar, programaEliminar)">
                            Eliminar
                        </button>
                    }
                    else
                    {
                        <span class="text-muted">Solo lectura</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private string rol = "";

    private List<Dictionary<string, object?>> registros = new();
    private List<Dictionary<string, object?>> aspectosLista = new();
    private List<Dictionary<string, object?>> programasLista = new();

    private string aspectoNormativo = "";
    private string programa = "";
    private string mensaje = "";

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
        await CargarAspectos();
        await CargarProgramas();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            rol = await JS.InvokeAsync<string>("localStorage.getItem", "rol") ?? "";
            StateHasChanged();
        }
    }

    private async Task CargarDatos()
    {
        registros = await Api.ListarAsync("AnPrograma");
    }

    private async Task CargarAspectos()
    {
        aspectosLista = await Api.ListarAsync("AspectoNormativo");
    }

    private async Task CargarProgramas()
    {
        programasLista = await Api.ListarAsync("Programa");
    }

    private async Task Guardar()
    {
        if (rol == "Consultor")
        {
            mensaje = "No tienes permiso para guardar información. Tu rol es Consultor.";
            return;
        }

        if (string.IsNullOrWhiteSpace(aspectoNormativo) ||
            string.IsNullOrWhiteSpace(programa))
        {
            mensaje = "Completa todos los campos.";
            return;
        }

        var datos = new Dictionary<string, object?>
        {
            { "aspectoNormativo", aspectoNormativo },
            { "programa", programa }
        };

        var resultado = await Api.CrearAsync("AnPrograma", datos);
        mensaje = resultado.mensaje;

        if (resultado.exito)
        {
            Limpiar();
            await CargarDatos();
        }
    }

    private async Task Eliminar(string aspectoEliminar, string programaEliminar)
    {
        if (rol != "Administrador")
        {
            mensaje = "Solo el Administrador puede eliminar registros.";
            return;
        }

        var resultado = await Api.EliminarCompuestoAsync("AnPrograma",
            new Dictionary<string, string>
            {
                { "aspectoNormativo", aspectoEliminar },
                { "programa", programaEliminar }
            });

        mensaje = resultado.mensaje;
        await CargarDatos();
    }

    private void Limpiar()
    {
        aspectoNormativo = "";
        programa = "";
        mensaje = "";
    }
}