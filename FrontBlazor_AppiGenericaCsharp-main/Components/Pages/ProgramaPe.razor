@page "/programa_pe"
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<div class="crud-header">
    <div>
        <span>Relación estratégica</span>
        <h2>Programas por Práctica Estratégica</h2>
        <p>Asocia programas académicos con prácticas estratégicas para fortalecer la innovación universitaria.</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(rol))
    {
        <strong class="role-pill">@rol</strong>
    }
</div>

<div class="mb-3">
    <label>Programa</label>
    <select class="form-control" @bind="programa">
        <option value="">Seleccione un programa</option>
        @foreach (var pro in programasLista)
        {
            <option value="@pro["id"]">@pro["nombre"]</option>
        }
    </select>
</div>

<div class="mb-3">
    <label>Práctica Estrategia</label>
    <select class="form-control" @bind="practicaEstrategia">
        <option value="">Seleccione una práctica</option>
        @foreach (var p in practicasLista)
        {
            <option value="@p["id"]">@p["nombre"]</option>
        }
    </select>
</div>

<div class="mb-3">
    @if (rol == "Administrador" || rol == "Docente")
    {
        <button class="btn btn-primary me-2" @onclick="Guardar">
            Guardar
        </button>

        <button class="btn btn-secondary" @onclick="Limpiar">
            Limpiar
        </button>
    }
    else if (rol == "Consultor")
    {
        <div class="alert alert-warning">
            Estás ingresando como Consultor. Solo puedes visualizar la información.
        </div>
    }
</div>

@if (!string.IsNullOrWhiteSpace(mensaje))
{
    <div class="alert alert-info">@mensaje</div>
}

<h4>Listado de Programa_pe</h4>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Programa</th>
            <th>Práctica Estrategia</th>
            <th>Acciones</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in registros)
        {
            var programaEliminar = item["programa"]?.ToString() ?? "";
            var practicaEliminar = item["practicaEstrategia"]?.ToString() ?? "";

            <tr>
                <td>@item["programa"]</td>
                <td>@item["practicaEstrategia"]</td>
                <td>
                    @if (rol == "Administrador")
                    {
                        <button class="btn btn-sm btn-danger" @onclick="() => Eliminar(programaEliminar, practicaEliminar)">
                            Eliminar
                        </button>
                    }
                    else
                    {
                        <span class="text-muted">Solo lectura</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private string rol = "";

    private List<Dictionary<string, object?>> registros = new();
    private List<Dictionary<string, object?>> programasLista = new();
    private List<Dictionary<string, object?>> practicasLista = new();

    private string programa = "";
    private string practicaEstrategia = "";
    private string mensaje = "";

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
        await CargarProgramas();
        await CargarPracticas();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            rol = await JS.InvokeAsync<string>("localStorage.getItem", "rol") ?? "";
            StateHasChanged();
        }
    }

    private async Task CargarDatos()
    {
        registros = await Api.ListarAsync("ProgramaPe");
    }

    private async Task CargarProgramas()
    {
        programasLista = await Api.ListarAsync("Programa");
    }

    private async Task CargarPracticas()
    {
        practicasLista = await Api.ListarAsync("PracticaEstrategia");
    }

    private async Task Guardar()
    {
        if (rol == "Consultor")
        {
            mensaje = "No tienes permiso para guardar información. Tu rol es Consultor.";
            return;
        }

        if (string.IsNullOrWhiteSpace(programa) ||
            string.IsNullOrWhiteSpace(practicaEstrategia))
        {
            mensaje = "Completa todos los campos.";
            return;
        }

        var datos = new Dictionary<string, object?>
        {
            { "programa", programa },
            { "practicaEstrategia", practicaEstrategia }
        };

        var resultado = await Api.CrearAsync("ProgramaPe", datos);
        mensaje = resultado.mensaje;

        if (resultado.exito)
        {
            Limpiar();
            await CargarDatos();
        }
    }

    private async Task Eliminar(string programaEliminar, string practicaEliminar)
    {
        if (rol != "Administrador")
        {
            mensaje = "Solo el Administrador puede eliminar registros.";
            return;
        }

        var resultado = await Api.EliminarCompuestoAsync("ProgramaPe",
            new Dictionary<string, string>
            {
                { "programa", programaEliminar },
                { "practicaEstrategia", practicaEliminar }
            });

        mensaje = resultado.mensaje;
        await CargarDatos();
    }

    private void Limpiar()
    {
        programa = "";
        practicaEstrategia = "";
        mensaje = "";
    }
}