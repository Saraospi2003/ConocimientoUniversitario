@page "/premio"
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<div class="crud-header">
    <div>
        <span>Módulo de reconocimientos</span>
        <h2>Gestión de Premios</h2>
        <p>Administra premios, entidades otorgantes, países, fechas y programas académicos asociados.</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(rol))
    {
        <strong class="role-pill">@rol</strong>
    }
</div>
<div class="mb-3"><label>ID</label><input class="form-control" @bind="id" /></div>
<div class="mb-3"><label>Nombre</label><input class="form-control" @bind="nombre" /></div>
<div class="mb-3"><label>Descripción</label><input class="form-control" @bind="descripcion" /></div>
<div class="mb-3"><label>Fecha</label><input type="date" class="form-control" @bind="fecha" /></div>
<div class="mb-3"><label>Entidad otorgante</label><input class="form-control" @bind="entidadOtorgante" /></div>
<div class="mb-3"><label>País</label><input class="form-control" @bind="pais" /></div>

<div class="mb-3">
    <label>Programa</label>
    <select class="form-control" @bind="programa">
        <option value="">Seleccione un programa</option>

        @foreach (var pro in programasLista)
        {
            <option value="@pro["id"]">@pro["nombre"]</option>
        }
    </select>
</div>

<div class="mb-3">
    @if (rol == "Administrador" || rol == "Docente")
    {
        <button class="btn btn-primary me-2" @onclick="Guardar">Guardar</button>
        <button class="btn btn-warning me-2" @onclick="Actualizar">Actualizar</button>
        <button class="btn btn-secondary" @onclick="Limpiar">Limpiar</button>
    }
    else if (rol == "Consultor")
    {
        <div class="alert alert-warning">
            Estás ingresando como Consultor. Solo puedes visualizar la información.
        </div>
    }
</div>

@if (!string.IsNullOrWhiteSpace(mensaje))
{
    <div class="alert alert-info">@mensaje</div>
}

<h4>Listado de premios</h4>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>ID</th>
            <th>Nombre</th>
            <th>Programa</th>
            <th>Acciones</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in premios)
        {
            var idEliminar = item["id"]?.ToString() ?? "";

            <tr>
                <td>@item["id"]</td>
                <td>@item["nombre"]</td>
                <td>@item["programa"]</td>
                <td>
                    @if (rol == "Administrador" || rol == "Docente")
                    {
                        <button class="btn btn-sm btn-info me-1" @onclick="() => Seleccionar(item)">
                            Editar
                        </button>
                    }

                    @if (rol == "Administrador")
                    {
                        <button class="btn btn-sm btn-danger" @onclick="() => Eliminar(idEliminar)">
                            Eliminar
                        </button>
                    }

                    @if (rol == "Consultor")
                    {
                        <span class="text-muted">Solo lectura</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private string rol = "";
    private List<Dictionary<string, object?>> premios = new();
    private List<Dictionary<string, object?>> programasLista = new();

    private string id = "";
    private string nombre = "";
    private string descripcion = "";
    private string entidadOtorgante = "";
    private string pais = "";
    private string programa = "";
    private string mensaje = "";

    private DateTime? fecha;

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
        await CargarProgramas();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            rol = await JS.InvokeAsync<string>("localStorage.getItem", "rol") ?? "";
            StateHasChanged();
        }
    }

    private async Task CargarDatos()
    {
        premios = await Api.ListarAsync("Premio");
    }

    private async Task CargarProgramas()
    {
        programasLista = await Api.ListarAsync("Programa");
    }

    private async Task Guardar()
    {
        if (rol == "Consultor")
        {
            mensaje = "No tienes permiso para guardar información. Tu rol es Consultor.";
            return;
        }

        var datos = new Dictionary<string, object?>
        {
            { "id", id },
            { "nombre", nombre },
            { "descripcion", descripcion },
            { "fecha", fecha?.ToString("yyyy-MM-dd") },
            { "entidadOtorgante", entidadOtorgante },
            { "pais", pais },
            { "programa", programa }
        };

        var resultado = await Api.CrearAsync("Premio", datos);
        mensaje = resultado.mensaje;

        if (resultado.exito)
        {
            Limpiar();
            await CargarDatos();
        }
    }

    private async Task Actualizar()
    {
        if (rol == "Consultor")
        {
            mensaje = "No tienes permiso para actualizar información. Tu rol es Consultor.";
            return;
        }

        var datos = new Dictionary<string, object?>
        {
            { "id", id },
            { "nombre", nombre },
            { "descripcion", descripcion },
            { "fecha", fecha?.ToString("yyyy-MM-dd") },
            { "entidadOtorgante", entidadOtorgante },
            { "pais", pais },
            { "programa", programa }
        };

        var resultado = await Api.ActualizarAsync("Premio", "id", id, datos);
        mensaje = resultado.mensaje;

        if (resultado.exito)
        {
            Limpiar();
            await CargarDatos();
        }
    }

    private async Task Eliminar(string idEliminar)
    {
        if (rol != "Administrador")
        {
            mensaje = "Solo el Administrador puede eliminar registros.";
            return;
        }

        var resultado = await Api.EliminarAsync("Premio", "id", idEliminar);
        mensaje = resultado.mensaje;
        await CargarDatos();
    }

    private void Seleccionar(Dictionary<string, object?> item)
    {
        if (rol == "Consultor")
        {
            mensaje = "No tienes permiso para editar. Tu rol es Consultor.";
            return;
        }

        id = item["id"]?.ToString() ?? "";
        nombre = item["nombre"]?.ToString() ?? "";
        descripcion = item["descripcion"]?.ToString() ?? "";
        entidadOtorgante = item["entidadOtorgante"]?.ToString() ?? "";
        pais = item["pais"]?.ToString() ?? "";
        programa = item["programa"]?.ToString() ?? "";

        if (DateTime.TryParse(item["fecha"]?.ToString(), out var f))
        {
            fecha = f;
        }
        else
        {
            fecha = null;
        }

        mensaje = "Registro cargado para edición.";
    }

    private void Limpiar()
    {
        id = "";
        nombre = "";
        descripcion = "";
        entidadOtorgante = "";
        pais = "";
        programa = "";
        mensaje = "";
        fecha = null;
    }
}