@page "/facultad"
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<div class="crud-header">
    <div>
        <span>Módulo académico</span>
        <h2>Gestión de Facultades</h2>
        <p>Consulta y administra la información de las facultades universitarias y su relación con universidades.</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(rol))
    {
        <strong class="role-pill">@rol</strong>
    }
</div>

<div class="mb-3">
    <label>ID</label>
    <input class="form-control" @bind="id" />
</div>

<div class="mb-3">
    <label>Nombre</label>
    <input class="form-control" @bind="nombre" />
</div>

<div class="mb-3">
    <label>Tipo</label>
    <input class="form-control" @bind="tipo" />
</div>

<div class="mb-3">
    <label>Fecha inicio</label>
    <input type="date" class="form-control" @bind="fechaIn" />
</div>

<div class="mb-3">
    <label>Universidad</label>
    <select class="form-control" @bind="universidad">
        <option value="">Seleccione una universidad</option>

        @foreach (var uni in universidades)
        {
            <option value="@uni["id"]">@uni["nombre"]</option>
        }
    </select>
</div>

<div class="mb-3">
    @if (rol == "Administrador" || rol == "Docente")
    {
        <button class="btn btn-primary me-2" @onclick="Guardar">
            Guardar
        </button>

        <button class="btn btn-warning me-2" @onclick="Actualizar">
            Actualizar
        </button>

        <button class="btn btn-secondary" @onclick="Limpiar">
            Limpiar
        </button>
    }
    else if (rol == "Consultor")
    {
        <div class="alert alert-warning">
            Estás ingresando como Consultor. Solo puedes visualizar la información.
        </div>
    }
</div>

@if (!string.IsNullOrWhiteSpace(mensaje))
{
    <div class="alert alert-info">@mensaje</div>
}

<h4>Listado de facultades</h4>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>ID</th>
            <th>Nombre</th>
            <th>Tipo</th>
            <th>Fecha inicio</th>
            <th>Universidad</th>
            <th>Acciones</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in facultades)
        {
            var idEliminar = item["id"]?.ToString() ?? "";

            <tr>
                <td>@item["id"]</td>
                <td>@item["nombre"]</td>
                <td>@item["tipo"]</td>
                <td>@item["fechaIn"]</td>
                <td>@item["universidad"]</td>
                <td>
                    @if (rol == "Administrador" || rol == "Docente")
                    {
                        <button class="btn btn-sm btn-info me-1" @onclick="() => Seleccionar(item)">
                            Editar
                        </button>
                    }

                    @if (rol == "Administrador")
                    {
                        <button class="btn btn-sm btn-danger" @onclick="() => Eliminar(idEliminar)">
                            Eliminar
                        </button>
                    }

                    @if (rol == "Consultor")
                    {
                        <span class="text-muted">Solo lectura</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private List<Dictionary<string, object?>> facultades = new();
    private List<Dictionary<string, object?>> universidades = new();

    private string rol = "";
    private bool cargadoRol = false;

    private string id = "";
    private string nombre = "";
    private string tipo = "";
    private string universidad = "";
    private string mensaje = "";

    private DateTime? fechaIn;

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
        await CargarUniversidades();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            rol = await JS.InvokeAsync<string>("localStorage.getItem", "rol") ?? "";
            cargadoRol = true;
            StateHasChanged();
        }
    }

    private async Task CargarDatos()
    {
        facultades = await Api.ListarAsync("Facultad");
    }

    private async Task CargarUniversidades()
    {
        universidades = await Api.ListarAsync("Universidad");
    }

    private async Task Guardar()
    {
        if (rol == "Consultor")
        {
            mensaje = "No tienes permiso para guardar información. Tu rol es Consultor.";
            return;
        }

        if (string.IsNullOrWhiteSpace(id) ||
            string.IsNullOrWhiteSpace(nombre) ||
            string.IsNullOrWhiteSpace(tipo) ||
            !fechaIn.HasValue ||
            string.IsNullOrWhiteSpace(universidad))
        {
            mensaje = "Completa todos los campos.";
            StateHasChanged();
            return;
        }

        var datos = new Dictionary<string, object?>
        {
            { "id", id },
            { "nombre", nombre },
            { "tipo", tipo },
            { "fechaIn", fechaIn?.ToString("yyyy-MM-dd") },
            { "universidad", universidad }
        };

        var resultado = await Api.CrearAsync("Facultad", datos);
        mensaje = resultado.mensaje;

        if (resultado.exito)
        {
            Limpiar();
            await CargarDatos();
        }
    }

    private async Task Actualizar()
    {
        if (rol == "Consultor")
        {
            mensaje = "No tienes permiso para actualizar información. Tu rol es Consultor.";
            return;
        }

        if (string.IsNullOrWhiteSpace(id) ||
            string.IsNullOrWhiteSpace(nombre) ||
            string.IsNullOrWhiteSpace(tipo) ||
            !fechaIn.HasValue ||
            string.IsNullOrWhiteSpace(universidad))
        {
            mensaje = "Completa todos los campos.";
            StateHasChanged();
            return;
        }

        var datos = new Dictionary<string, object?>
        {
            { "id", id },
            { "nombre", nombre },
            { "tipo", tipo },
            { "fechaIn", fechaIn?.ToString("yyyy-MM-dd") },
            { "universidad", universidad }
        };

        var resultado = await Api.ActualizarAsync("Facultad", "id", id, datos);
        mensaje = resultado.mensaje;

        if (resultado.exito)
        {
            Limpiar();
            await CargarDatos();
        }
    }

    private async Task Eliminar(string idEliminar)
    {
        if (rol != "Administrador")
        {
            mensaje = "Solo el Administrador puede eliminar registros.";
            return;
        }

        var resultado = await Api.EliminarAsync("Facultad", "id", idEliminar);
        mensaje = resultado.mensaje;
        await CargarDatos();
    }

    private void Seleccionar(Dictionary<string, object?> item)
    {
        if (rol == "Consultor")
        {
            mensaje = "No tienes permiso para editar. Tu rol es Consultor.";
            return;
        }

        id = item["id"]?.ToString() ?? "";
        nombre = item["nombre"]?.ToString() ?? "";
        tipo = item["tipo"]?.ToString() ?? "";
        universidad = item["universidad"]?.ToString() ?? "";

        if (DateTime.TryParse(item["fechaIn"]?.ToString(), out var f))
        {
            fechaIn = f;
        }
        else
        {
            fechaIn = null;
        }

        mensaje = "Registro cargado para edición.";
    }

    private void Limpiar()
    {
        id = "";
        nombre = "";
        tipo = "";
        fechaIn = null;
        universidad = "";
        mensaje = "";
    }
}