@page "/programa"
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<div class="crud-header">
    <div>
        <span>Módulo académico</span>
        <h2>Gestión de Programas Académicos</h2>
        <p>Administra programas, niveles, fechas, cohortes, graduados, ciudades y facultades asociadas.</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(rol))
    {
        <strong class="role-pill">@rol</strong>
    }
</div>

<div class="mb-3">
    <label>ID</label>
    <input class="form-control" @bind="id" />
</div>

<div class="mb-3">
    <label>Nombre</label>
    <input class="form-control" @bind="nombre" />
</div>

<div class="mb-3">
    <label>Tipo</label>
    <input class="form-control" @bind="tipo" />
</div>

<div class="mb-3">
    <label>Nivel</label>
    <input class="form-control" @bind="nivel" />
</div>

<div class="mb-3">
    <label>Fecha creación</label>
    <input type="date" class="form-control" @bind="fechaCreacion" />
</div>

<div class="mb-3">
    <label>Fecha cierre</label>
    <input type="date" class="form-control" @bind="fechaCierre" />
</div>

<div class="mb-3">
    <label>Número cohortes</label>
    <input class="form-control" @bind="numCohortes" />
</div>

<div class="mb-3">
    <label>Cantidad graduados</label>
    <input class="form-control" @bind="cantGraduados" />
</div>

<div class="mb-3">
    <label>Fecha actualización</label>
    <input type="date" class="form-control" @bind="fechaActualizacion" />
</div>

<div class="mb-3">
    <label>Ciudad</label>
    <input class="form-control" @bind="ciudad" />
</div>

<div class="mb-3">
    <label>Facultad</label>
    <select class="form-control" @bind="facultadId">
        <option value="">Seleccione una facultad</option>

        @foreach (var fac in facultadesLista)
        {
            <option value="@fac["id"]">@fac["nombre"]</option>
        }
    </select>
</div>

<div class="mb-3">
    @if (rol == "Administrador" || rol == "Docente")
    {
        <button class="btn btn-primary me-2" @onclick="Guardar">
            Guardar
        </button>

        <button class="btn btn-warning me-2" @onclick="Actualizar">
            Actualizar
        </button>

        <button class="btn btn-secondary" @onclick="Limpiar">
            Limpiar
        </button>
    }
    else if (rol == "Consultor")
    {
        <div class="alert alert-warning">
            Estás ingresando como Consultor. Solo puedes visualizar la información.
        </div>
    }
</div>

@if (!string.IsNullOrWhiteSpace(mensaje))
{
    <div class="alert alert-info">@mensaje</div>
}

<h4>Listado de programas</h4>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>ID</th>
            <th>Nombre</th>
            <th>Tipo</th>
            <th>Nivel</th>
            <th>Ciudad</th>
            <th>Facultad</th>
            <th>Acciones</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in programas)
        {
            var idEliminar = item["id"]?.ToString() ?? "";

            <tr>
                <td>@item["id"]</td>
                <td>@item["nombre"]</td>
                <td>@item["tipo"]</td>
                <td>@item["nivel"]</td>
                <td>@item["ciudad"]</td>
                <td>@item["facultad"]</td>
                <td>
                    @if (rol == "Administrador" || rol == "Docente")
                    {
                        <button class="btn btn-sm btn-info me-1" @onclick="() => Seleccionar(item)">
                            Editar
                        </button>
                    }

                    @if (rol == "Administrador")
                    {
                        <button class="btn btn-sm btn-danger" @onclick="() => Eliminar(idEliminar)">
                            Eliminar
                        </button>
                    }

                    @if (rol == "Consultor")
                    {
                        <span class="text-muted">Solo lectura</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private List<Dictionary<string, object?>> programas = new();
    private List<Dictionary<string, object?>> facultadesLista = new();

    private string rol = "";
    private bool cargadoRol = false;

    private int? id;
    private string nombre = "";
    private string tipo = "";
    private string nivel = "";
    private string ciudad = "";
    private string mensaje = "";

    private DateTime? fechaCreacion;
    private DateTime? fechaCierre;
    private DateTime? fechaActualizacion;

    private int? numCohortes;
    private int? cantGraduados;
    private int? facultadId;

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
        await CargarFacultades();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            rol = await JS.InvokeAsync<string>("localStorage.getItem", "rol") ?? "";
            cargadoRol = true;
            StateHasChanged();
        }
    }

    private async Task CargarDatos()
    {
        programas = await Api.ListarAsync("Programa");
    }

    private async Task CargarFacultades()
    {
        facultadesLista = await Api.ListarAsync("Facultad");
    }

    private async Task Guardar()
    {
        if (rol == "Consultor")
        {
            mensaje = "No tienes permiso para guardar información. Tu rol es Consultor.";
            return;
        }

        if (id == null ||
            string.IsNullOrWhiteSpace(nombre) ||
            string.IsNullOrWhiteSpace(tipo) ||
            string.IsNullOrWhiteSpace(nivel) ||
            fechaCreacion == null ||
            fechaCierre == null ||
            numCohortes == null ||
            cantGraduados == null ||
            fechaActualizacion == null ||
            string.IsNullOrWhiteSpace(ciudad) ||
            facultadId == null)
        {
            mensaje = "Completa todos los campos.";
            return;
        }

        var datos = new Dictionary<string, object?>
        {
            { "id", id },
            { "nombre", nombre },
            { "tipo", tipo },
            { "nivel", nivel },
            { "fechaCreacion", fechaCreacion },
            { "fechaCierre", fechaCierre },
            { "numCohortes", numCohortes },
            { "cantGraduados", cantGraduados },
            { "fechaActualizacion", fechaActualizacion },
            { "ciudad", ciudad },
            { "facultad", facultadId }
        };

        var resultado = await Api.CrearAsync("Programa", datos);
        mensaje = resultado.mensaje;

        if (resultado.exito)
        {
            Limpiar();
            await CargarDatos();
        }
    }

    private async Task Actualizar()
    {
        if (rol == "Consultor")
        {
            mensaje = "No tienes permiso para actualizar información. Tu rol es Consultor.";
            return;
        }

        if (id == null)
        {
            mensaje = "Selecciona un registro para actualizar.";
            return;
        }

        var datos = new Dictionary<string, object?>
        {
            { "id", id },
            { "nombre", nombre },
            { "tipo", tipo },
            { "nivel", nivel },
            { "fechaCreacion", fechaCreacion },
            { "fechaCierre", fechaCierre },
            { "numCohortes", numCohortes },
            { "cantGraduados", cantGraduados },
            { "fechaActualizacion", fechaActualizacion },
            { "ciudad", ciudad },
            { "facultad", facultadId }
        };

        var resultado = await Api.ActualizarAsync("Programa", "id", id?.ToString() ?? "", datos);
        mensaje = resultado.mensaje;

        if (resultado.exito)
        {
            Limpiar();
            await CargarDatos();
        }
    }

    private async Task Eliminar(string idEliminar)
    {
        if (rol != "Administrador")
        {
            mensaje = "Solo el Administrador puede eliminar registros.";
            return;
        }

        var resultado = await Api.EliminarAsync("Programa", "id", idEliminar);
        mensaje = resultado.mensaje;
        await CargarDatos();
    }

    private void Seleccionar(Dictionary<string, object?> item)
    {
        if (rol == "Consultor")
        {
            mensaje = "No tienes permiso para editar. Tu rol es Consultor.";
            return;
        }

        id = int.TryParse(item["id"]?.ToString(), out var i) ? i : null;
        nombre = item["nombre"]?.ToString() ?? "";
        tipo = item["tipo"]?.ToString() ?? "";
        nivel = item["nivel"]?.ToString() ?? "";

        fechaCreacion = DateTime.TryParse(item["fechaCreacion"]?.ToString(), out var fc) ? fc : null;
        fechaCierre = DateTime.TryParse(item["fechaCierre"]?.ToString(), out var ff) ? ff : null;
        fechaActualizacion = DateTime.TryParse(item["fechaActualizacion"]?.ToString(), out var fa) ? fa : null;

        numCohortes = int.TryParse(item["numCohortes"]?.ToString(), out var nc) ? nc : null;
        cantGraduados = int.TryParse(item["cantGraduados"]?.ToString(), out var cg) ? cg : null;

        ciudad = item["ciudad"]?.ToString() ?? "";
        facultadId = int.TryParse(item["facultad"]?.ToString(), out var f) ? f : null;

        mensaje = "Registro cargado para edición.";
    }

    private void Limpiar()
    {
        id = null;
        nombre = "";
        tipo = "";
        nivel = "";
        fechaCreacion = null;
        fechaCierre = null;
        numCohortes = null;
        cantGraduados = null;
        fechaActualizacion = null;
        ciudad = "";
        facultadId = null;
        mensaje = "";
    }
}