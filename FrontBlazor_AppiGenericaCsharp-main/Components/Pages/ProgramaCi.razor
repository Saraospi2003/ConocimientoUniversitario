@page "/programa_ci"
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<div class="crud-header">
    <div>
        <span>Relación de innovación</span>
        <h2>Programas por Característica de Innovación</h2>
        <p>Asocia programas académicos con características de innovación institucional.</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(rol))
    {
        <strong class="role-pill">@rol</strong>
    }
</div>

<div class="mb-3">
    <label>Programa</label>
    <select class="form-control" @bind="programa">
        <option value="">Seleccione un programa</option>
        @foreach (var pro in programasLista)
        {
            <option value="@pro["id"]">@pro["nombre"]</option>
        }
    </select>
</div>

<div class="mb-3">
    <label>Car Innovación</label>
    <select class="form-control" @bind="carInnovacion">
        <option value="">Seleccione una característica</option>
        @foreach (var car in carInnovaciones)
        {
            <option value="@car["id"]">@car["nombre"]</option>
        }
    </select>
</div>

<div class="mb-3">
    @if (rol == "Administrador" || rol == "Docente")
    {
        <button class="btn btn-primary me-2" @onclick="Guardar">
            Guardar
        </button>

        <button class="btn btn-secondary" @onclick="Limpiar">
            Limpiar
        </button>
    }
    else if (rol == "Consultor")
    {
        <div class="alert alert-warning">
            Estás ingresando como Consultor. Solo puedes visualizar la información.
        </div>
    }
</div>

@if (!string.IsNullOrWhiteSpace(mensaje))
{
    <div class="alert alert-info">@mensaje</div>
}

<h4>Listado de Programa_ci</h4>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Programa</th>
            <th>Car Innovación</th>
            <th>Acciones</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in registros)
        {
            var programaEliminar = item["programa"]?.ToString() ?? "";
            var carEliminar = item["carInnovacion"]?.ToString() ?? "";

            <tr>
                <td>@item["programa"]</td>
                <td>@item["carInnovacion"]</td>
                <td>
                    @if (rol == "Administrador")
                    {
                        <button class="btn btn-sm btn-danger" @onclick="() => Eliminar(programaEliminar, carEliminar)">
                            Eliminar
                        </button>
                    }
                    else
                    {
                        <span class="text-muted">Solo lectura</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private string rol = "";

    private List<Dictionary<string, object?>> registros = new();
    private List<Dictionary<string, object?>> programasLista = new();
    private List<Dictionary<string, object?>> carInnovaciones = new();

    private string programa = "";
    private string carInnovacion = "";
    private string mensaje = "";

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
        await CargarProgramas();
        await CargarCarInnovaciones();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            rol = await JS.InvokeAsync<string>("localStorage.getItem", "rol") ?? "";
            StateHasChanged();
        }
    }

    private async Task CargarDatos()
    {
        registros = await Api.ListarAsync("ProgramaCi");
    }

    private async Task CargarProgramas()
    {
        programasLista = await Api.ListarAsync("Programa");
    }

    private async Task CargarCarInnovaciones()
    {
        carInnovaciones = await Api.ListarAsync("CarInnovacion");
    }

    private async Task Guardar()
    {
        if (rol == "Consultor")
        {
            mensaje = "No tienes permiso para guardar información. Tu rol es Consultor.";
            return;
        }

        if (string.IsNullOrWhiteSpace(programa) ||
            string.IsNullOrWhiteSpace(carInnovacion))
        {
            mensaje = "Completa todos los campos.";
            return;
        }

        var datos = new Dictionary<string, object?>
        {
            { "programa", programa },
            { "carInnovacion", carInnovacion }
        };

        var resultado = await Api.CrearAsync("ProgramaCi", datos);
        mensaje = resultado.mensaje;

        if (resultado.exito)
        {
            Limpiar();
            await CargarDatos();
        }
    }

    private async Task Eliminar(string programaEliminar, string carEliminar)
    {
        if (rol != "Administrador")
        {
            mensaje = "Solo el Administrador puede eliminar registros.";
            return;
        }

        var resultado = await Api.EliminarCompuestoAsync("ProgramaCi",
            new Dictionary<string, string>
            {
                { "programa", programaEliminar },
                { "carInnovacion", carEliminar }
            });

        mensaje = resultado.mensaje;
        await CargarDatos();
    }

    private void Limpiar()
    {
        programa = "";
        carInnovacion = "";
        mensaje = "";
    }
}