@page "/aarc"
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<div class="crud-header">
    <div>
        <span>Relación académica</span>
        <h2>Actividades Académicas y Registros Calificados</h2>
        <p>Asocia actividades académicas con registros calificados, componente y semestre.</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(rol))
    {
        <strong class="role-pill">@rol</strong>
    }
</div>

<div class="mb-3">
    <label>Actividad Académica</label>
    <select class="form-control" @bind="activAcademica">
        <option value="">Seleccione una actividad</option>
        @foreach (var act in actividadesLista)
        {
            <option value="@act["id"]">@act["nombre"]</option>
        }
    </select>
</div>

<div class="mb-3">
    <label>Registro Calificado</label>
    <select class="form-control" @bind="registroCalificado">
        <option value="">Seleccione un registro</option>
        @foreach (var reg in registrosCalificadosLista)
        {
            <option value="@reg["codigo"]">@reg["codigo"]</option>
        }
    </select>
</div>

<div class="mb-3">
    <label>Componente</label>
    <input class="form-control" @bind="componente" />
</div>

<div class="mb-3">
    <label>Semestre</label>
    <input class="form-control" @bind="semestre" />
</div>

<div class="mb-3">
    @if (rol == "Administrador" || rol == "Docente")
    {
        <button class="btn btn-primary me-2" @onclick="Guardar">Guardar</button>
        <button class="btn btn-secondary" @onclick="Limpiar">Limpiar</button>
    }
    else if (rol == "Consultor")
    {
        <div class="alert alert-warning">
            Estás ingresando como Consultor. Solo puedes visualizar la información.
        </div>
    }
</div>

@if (!string.IsNullOrWhiteSpace(mensaje))
{
    <div class="alert alert-info">@mensaje</div>
}

<h4>Listado de aa_rc</h4>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Actividad Académica</th>
            <th>Registro Calificado</th>
            <th>Componente</th>
            <th>Semestre</th>
            <th>Acciones</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in registros)
        {
            var activEliminar = item["activAcademica"]?.ToString() ?? "";
            var registroEliminar = item["registroCalificado"]?.ToString() ?? "";

            <tr>
                <td>@item["activAcademica"]</td>
                <td>@item["registroCalificado"]</td>
                <td>@item["componente"]</td>
                <td>@item["semestre"]</td>
                <td>
                    @if (rol == "Administrador")
                    {
                        <button class="btn btn-sm btn-danger" @onclick="() => Eliminar(activEliminar, registroEliminar)">
                            Eliminar
                        </button>
                    }
                    else
                    {
                        <span class="text-muted">Solo lectura</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private string rol = "";

    private List<Dictionary<string, object?>> registros = new();
    private List<Dictionary<string, object?>> actividadesLista = new();
    private List<Dictionary<string, object?>> registrosCalificadosLista = new();

    private string activAcademica = "";
    private string registroCalificado = "";
    private string componente = "";
    private string semestre = "";
    private string mensaje = "";

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
        await CargarActividades();
        await CargarRegistrosCalificados();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            rol = await JS.InvokeAsync<string>("localStorage.getItem", "rol") ?? "";
            StateHasChanged();
        }
    }

    private async Task CargarDatos()
    {
        registros = await Api.ListarAsync("AaRc");
    }

    private async Task CargarActividades()
    {
        actividadesLista = await Api.ListarAsync("ActivAcademica");
    }

    private async Task CargarRegistrosCalificados()
    {
        registrosCalificadosLista = await Api.ListarAsync("RegistroCalificado");
    }

    private async Task Guardar()
    {
        if (rol == "Consultor")
        {
            mensaje = "No tienes permiso para guardar información. Tu rol es Consultor.";
            return;
        }

        if (string.IsNullOrWhiteSpace(activAcademica) ||
            string.IsNullOrWhiteSpace(registroCalificado) ||
            string.IsNullOrWhiteSpace(componente) ||
            string.IsNullOrWhiteSpace(semestre))
        {
            mensaje = "Completa todos los campos.";
            return;
        }

        var datos = new Dictionary<string, object?>
        {
            { "activAcademica", activAcademica },
            { "registroCalificado", registroCalificado },
            { "componente", componente },
            { "semestre", semestre }
        };

        var resultado = await Api.CrearAsync("AaRc", datos);
        mensaje = resultado.mensaje;

        if (resultado.exito)
        {
            Limpiar();
            await CargarDatos();
        }
    }

    private async Task Eliminar(string activEliminar, string registroEliminar)
    {
        if (rol != "Administrador")
        {
            mensaje = "Solo el Administrador puede eliminar registros.";
            return;
        }

        var resultado = await Api.EliminarCompuestoAsync("AaRc",
            new Dictionary<string, string>
            {
                { "activAcademica", activEliminar },
                { "registroCalificado", registroEliminar }
            });

        mensaje = resultado.mensaje;
        await CargarDatos();
    }

    private void Limpiar()
    {
        activAcademica = "";
        registroCalificado = "";
        componente = "";
        semestre = "";
        mensaje = "";
    }
}