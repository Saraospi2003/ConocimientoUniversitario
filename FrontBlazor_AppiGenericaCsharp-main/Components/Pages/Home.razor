@page "/"
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject NavigationManager Nav

<div class="home-container">

    @if (!cargado)
    {
        <div class="loading-card">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-3">Cargando información del usuario...</p>
        </div>
    }
    else if (string.IsNullOrEmpty(nombre))
    {
        <section class="hero-card">
            <div class="hero-content">
                <span class="badge-custom">Sistema de Innovación Universitaria</span>

                <h1>Bienvenido al sistema</h1>

                <p>
                    Plataforma para gestionar información académica relacionada con universidades,
                    facultades, programas, acreditaciones, innovación curricular y procesos institucionales.
                </p>

                <div class="hero-buttons">
                    <button class="btn btn-primary btn-lg" @onclick="IrLogin">
                        Iniciar sesión
                    </button>

                    <button class="btn btn-outline-primary btn-lg" @onclick="IrRegistro">
                        Registrarse
                    </button>
                </div>
            </div>

            <div class="hero-panel">
                <h4>Roles disponibles</h4>

                <div class="role-mini-card admin">
                    <strong>Administrador</strong>
                    <span>Acceso completo al sistema.</span>
                </div>

                <div class="role-mini-card docente">
                    <strong>Docente</strong>
                    <span>Puede registrar y actualizar información.</span>
                </div>

                <div class="role-mini-card consultor">
                    <strong>Consultor</strong>
                    <span>Solo puede visualizar los datos.</span>
                </div>
            </div>
        </section>

        <section class="roles-section">
            <h2>Control de acceso por roles</h2>
            <p class="section-subtitle">
                Cada usuario tiene permisos diferentes según el rol seleccionado al registrarse.
            </p>

            <div class="roles-grid">
                <div class="role-card admin-card">
                    <div class="role-icon">👑</div>
                    <h3>Administrador</h3>
                    <p>Gestiona todo el sistema.</p>

                    <ul>
                        <li>Puede ver todos los módulos.</li>
                        <li>Puede crear registros.</li>
                        <li>Puede editar registros.</li>
                        <li>Puede eliminar registros.</li>
                        <li>Puede gestionar usuarios.</li>
                        <li>Puede cambiar roles.</li>
                    </ul>
                </div>

                <div class="role-card docente-card">
                    <div class="role-icon">📚</div>
                    <h3>Docente</h3>
                    <p>Registra información académica.</p>

                    <ul>
                        <li>Puede iniciar sesión.</li>
                        <li>Puede consultar información.</li>
                        <li>Puede crear registros.</li>
                        <li>Puede editar registros.</li>
                        <li>No puede eliminar registros.</li>
                        <li>No puede cambiar roles.</li>
                    </ul>
                </div>

                <div class="role-card consultor-card">
                    <div class="role-icon">👁️</div>
                    <h3>Consultor</h3>
                    <p>Acceso de solo lectura.</p>

                    <ul>
                        <li>Puede iniciar sesión.</li>
                        <li>Puede ver la información.</li>
                        <li>No puede crear registros.</li>
                        <li>No puede editar registros.</li>
                        <li>No puede eliminar registros.</li>
                        <li>No puede administrar usuarios.</li>
                    </ul>
                </div>
            </div>
        </section>
    }
    else
    {
        <section class="welcome-card">
            <div>
                <span class="badge-custom">Sesión iniciada</span>
                <h1>Bienvenida, @nombre</h1>

                <p>
                    Has ingresado correctamente al sistema de gestión de innovación universitaria.
                </p>
            </div>

            <div class="current-role-card @ClaseRol">
                <span>Rol actual</span>
                <strong>@rol</strong>
            </div>
        </section>

        <section class="permission-card">
            <h2>¿Qué puedes hacer en la aplicación?</h2>

            @if (rol == "Administrador")
            {
                <div class="permission-banner admin-banner">
                    <h3>👑 Administrador</h3>
                    <p>Tienes acceso completo al sistema y puedes gestionar usuarios.</p>
                </div>

                <div class="permissions-grid">
                    <div>✅ Ver módulos</div>
                    <div>✅ Crear registros</div>
                    <div>✅ Editar registros</div>
                    <div>✅ Eliminar registros</div>
                    <div>✅ Gestionar usuarios</div>
                    <div>✅ Cambiar roles</div>
                </div>
            }
            else if (rol == "Docente")
            {
                <div class="permission-banner docente-banner">
                    <h3>📚 Docente</h3>
                    <p>Puedes registrar y actualizar información académica.</p>
                </div>

                <div class="permissions-grid">
                    <div>✅ Ver información</div>
                    <div>✅ Crear registros</div>
                    <div>✅ Editar registros</div>
                    <div>❌ Eliminar registros</div>
                    <div>❌ Gestionar usuarios</div>
                    <div>❌ Cambiar roles</div>
                </div>
            }
            else if (rol == "Consultor")
            {
                <div class="permission-banner consultor-banner">
                    <h3>👁️ Consultor</h3>
                    <p>Tienes acceso únicamente de visualización. No puedes modificar información.</p>
                </div>

                <div class="permissions-grid">
                    <div>✅ Ver información</div>
                    <div>✅ Consultar módulos</div>
                    <div>❌ Crear registros</div>
                    <div>❌ Editar registros</div>
                    <div>❌ Eliminar registros</div>
                    <div>❌ Gestionar usuarios</div>
                </div>
            }
            else
            {
                <div class="permission-banner">
                    <h3>Rol no identificado</h3>
                    <p>No se encontró un rol válido para este usuario.</p>
                </div>
            }
        </section>

        <section class="quick-access-card">
            <h2>Accesos rápidos</h2>
            <p>Opciones disponibles según tu rol.</p>

            <div class="quick-grid">

                @if (rol == "Administrador")
                {
                    <button class="quick-button" @onclick="IrUniversidad">
                        🏛️ Universidad
                    </button>

                    <button class="quick-button" @onclick="IrFacultad">
                        🎓 Facultad
                    </button>

                    <button class="quick-button" @onclick="IrPrograma">
                        📘 Programa
                    </button>

                    <button class="quick-button dark" @onclick="IrGestionUsuarios">
                        👥 Gestión de usuarios
                    </button>
                }

                @if (rol == "Docente")
                {
                    <button class="quick-button" @onclick="IrUniversidad">
                        🏛️ Universidad
                    </button>

                    <button class="quick-button" @onclick="IrFacultad">
                        🎓 Facultad
                    </button>

                    <button class="quick-button" @onclick="IrPrograma">
                        📘 Programa
                    </button>
                }

                @if (rol == "Consultor")
                {
                    <button class="quick-button" @onclick="IrUniversidad">
                        👁️ Ver universidades
                    </button>

                    <button class="quick-button" @onclick="IrFacultad">
                        👁️ Ver facultades
                    </button>

                    <button class="quick-button" @onclick="IrPrograma">
                        👁️ Ver programas
                    </button>
                }
            </div>
        </section>

        <button class="btn btn-danger logout-button" @onclick="CerrarSesion">
            Cerrar sesión
        </button>
    }
</div>

@code {
    private string nombre = "";
    private string rol = "";
    private bool cargado = false;

    private string ClaseRol =>
        rol == "Administrador" ? "admin-role" :
        rol == "Docente" ? "docente-role" :
        rol == "Consultor" ? "consultor-role" :
        "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            nombre = await JS.InvokeAsync<string>("localStorage.getItem", "nombre") ?? "";
            rol = await JS.InvokeAsync<string>("localStorage.getItem", "rol") ?? "";

            cargado = true;

            StateHasChanged();
        }
    }

    private void IrLogin()
    {
        Nav.NavigateTo("/login");
    }

    private void IrRegistro()
    {
        Nav.NavigateTo("/registro");
    }

    private void IrUniversidad()
    {
        Nav.NavigateTo("/universidad");
    }

    private void IrFacultad()
    {
        Nav.NavigateTo("/facultad");
    }

    private void IrPrograma()
    {
        Nav.NavigateTo("/programa");
    }

    private void IrGestionUsuarios()
    {
        Nav.NavigateTo("/gestion-usuarios");
    }

    private async Task CerrarSesion()
    {
        await JS.InvokeVoidAsync("localStorage.removeItem", "idUsuario");
        await JS.InvokeVoidAsync("localStorage.removeItem", "nombre");
        await JS.InvokeVoidAsync("localStorage.removeItem", "correo");
        await JS.InvokeVoidAsync("localStorage.removeItem", "rol");

        nombre = "";
        rol = "";

        Nav.NavigateTo("/", forceLoad: true);
    }
}